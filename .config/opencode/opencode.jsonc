{
  "$schema": "https://opencode.ai/config.json",
  "instructions": [
    "./prompts/Software_Engineering_Principles.md"
  ],
  "agent": {
    "build": {
      "mode": "primary",
      "model": "opencode-go/deepseek-v4-pro"
    },
    "plan": {
      "mode": "primary",
      "model": "opencode-go/qwen3.7-plus"
      // "model": "opencode-go/deepseek-v4-pro"
      // "model": "opencode-go/mimo-v2.5-pro"
      // "model": "opencode-go/kimi-k2.6"
    },
    "code-reviewer": {
      "mode": "subagent",
      "model": "opencode-go/qwen3.7-plus"
      // "model": "opencode-go/deepseek-v4-pro"
      // "model": "opencode-go/mimo-v2.5-pro"
      // "model": "opencode-go/kimi-k2.6"
    }
  }
}