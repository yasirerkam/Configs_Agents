        },
        "srv_mqn7g5ba77ae77c461be:deepseek-v4-flash": {
          "name": "VearyTry | DeepSeek:deepseek-v4-flash"
        },
        "srv_mp1v9cyha31b95fa8c9a:z-ai/glm-5.1": {
