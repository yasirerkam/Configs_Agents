{
  "$schema": "https://opencode.ai/config.json",
  "instructions": [
    "./prompts/Software_Engineering_Principles.md"
  ],
  "agent": {
    "build": {
      "mode": "primary",
      // "model": "opencode-go/qwen3.7-plus"
      // "model": "opencode-go/deepseek-v4-pro"
      // "model": "opencode-go/mimo-v2.5-pro"
      // "model": "opencode-go/kimi-k2.6"
      "model": "opencode-go/minimax-m3"
    },
    "plan": {
      "mode": "primary",
      // "model": "opencode-go/qwen3.7-plus"
      "model": "opencode-go/deepseek-v4-pro"
      // "model": "opencode-go/mimo-v2.5-pro"
      // "model": "opencode-go/kimi-k2.6"
      // "model": "opencode-go/minimax-m3"
    },
    "explore": {
      "mode": "subagent",
      "model": "opencode-go/mimo-v2.5"
      // "model": "opencode-go/deepseek-v4-flash"
    },
    "code-reviewer": {
      "description": "Reviews code for quality, performance, maintainability, and security best practices.",
      "mode": "subagent",
      "model": "opencode-go/qwen3.7-plus"
      // "model": "opencode-go/deepseek-v4-pro"
      // "model": "opencode-go/mimo-v2.5-pro"
      // "model": "opencode-go/kimi-k2.6"
      // "model": "opencode-go/minimax-m3"
    },
    "committer": {
      "description": "Analyzes file changes and automatically generates detailed, standardized Git commit messages.",
      "mode": "subagent",
      "model": "opencode-go/mimo-v2.5",
      "steps": 4,
      "prompt": "You are an expert Git commit agent. Workflow: 1. `git status` 2. `git diff` 3. `git add <files>` 4. `git commit`. CRITICAL RULES FOR COMMIT MESSAGE: You MUST use the Conventional Commits specification. DO NOT be lazy; write detailed messages. You MUST use multiple `-m` flags to bypass bash escaping issues. Example: `git commit -m \"feat(auth): add jwt validation\" -m \"- Implemented JWT logic in middleware. - Fixed token expiration bug. This ensures secure sessions.\"` The first `-m` is the Subject (<type>(<scope>): <short description>). The second `-m` is the Body, which MUST explain WHY the change was made and list specific changes using bullet points. CONSTRAINTS: DO NOT edit files, write code, or git push.",
      "permission": {
        "edit": "deny",
        "bash": {
          "*": "deny",
          "git status*": "allow",
          "git diff*": "allow",
          "git add *": "allow",
          "git commit *": "allow"
        }
      }
    }
  }
}