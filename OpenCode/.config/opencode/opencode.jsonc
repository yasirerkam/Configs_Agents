{
  "$schema": "https://opencode.ai/config.json",
  "provider": {},
  "agent": {
    "build": {
      "mode": "primary",
      "model": "LiteLLM-glm-5.2/glm-5.2",
      "fallback_models": [
        {
          "model": "OpenWebUI/glm-5.2"
          //"model": "LiteLLM-supergemma4/supergemma4"
        }
      ]
    },
    "plan": {
      "mode": "primary",
      "model": "LiteLLM-glm-5.2/glm-5.2",
      "fallback_models": [
        {
          "model": "OpenWebUI/glm-5.2"
          //"model": "LiteLLM-supergemma4/supergemma4"
        }
      ]
    },
    "explore": {
      "mode": "subagent",
      "model": "LiteLLM-glm-5.2/glm-5.2",
      "fallback_models": [
        {
          "model": "OpenWebUI/glm-5.2"
          //"model": "LiteLLM-supergemma4/supergemma4"
        }
      ]
    }
  },
  "plugin": [
    "@mohak34/opencode-notifier@latest",
    "oh-my-openagent@latest"
  ],
  "mcp": {
    "codebase-memory-mcp": {
      "type": "local",
      "command": [
        "codebase-memory-mcp.exe"
      ],
      "enabled": true
    }
  }
}