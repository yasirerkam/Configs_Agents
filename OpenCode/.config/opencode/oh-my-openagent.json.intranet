{
  "$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-openagent/dev/assets/oh-my-opencode.schema.json",
  "hashline_edit": true,
  "new_task_system_enabled": true,
  "runtime_fallback": {
    "enabled": true,
    "retry_on_errors": [
      400,
      401,
      403,
      404,
      429,
      500,
      502,
      503,
      504
    ],
    "max_fallback_attempts": 1,
    "cooldown_seconds": 15,
    "timeout_seconds": 10,
    "notify_on_fallback": true,
    "restore_primary_after_cooldown": true
  },
  "agents": {
    "sisyphus": {
      "model": "LiteLLM-glm-5.2/glm-5.2",
      "fallback_models": [
        {
          "model": "OpenWebUI/glm-5.2"
        }
      ]
    },
    "hephaestus": {
      "model": "LiteLLM-glm-5.2/glm-5.2",
      "fallback_models": [
        {
          "model": "OpenWebUI/glm-5.2"
        }
      ]
    },
    "oracle": {
